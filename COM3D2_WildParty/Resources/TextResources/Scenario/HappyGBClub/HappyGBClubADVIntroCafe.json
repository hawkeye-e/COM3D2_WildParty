  "hgbc_intro_cafe_0038b": {
    "ID": "hgbc_intro_cafe_0038b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0038c",
    "TalkData": {
      "SpeakerName": "男１",
      "Text": "[=Name,NPC_F,2,CallName]さん、来てくれたか！　いやぁ、今日もそのエロい体が最高だぜ！"
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "hgbc_intro_cafe_0038c": {
    "ID": "hgbc_intro_cafe_0038c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0039",
    "TalkData": {
      "SpeakerName": "男１",
      "Text": "ほら見てみろよ、俺のちんぽもうビンビンに勃起してる。[=Name,NPC_F,2,CallName]さんの名フェラでしゃぶり倒して、精液飲ませてくれよなぁ～！"
    }
  },

  "hgbc_intro_cafe_0039": {
    "ID": "hgbc_intro_cafe_0039",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0039a",
    "TalkData": {
      "SpeakerName": "男２",
      "Text": "[=Name,NPC_F,2,CallName]さん、今日はそのデカパイを存分に使わせてもらうぜ。"
    }
  },

  "hgbc_intro_cafe_0039a": {
    "ID": "hgbc_intro_cafe_0039a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0040",
    "TalkData": {
      "SpeakerName": "男２",
      "Text": "思いっきり揉みまくって、乳圧でちんぽしごいて、その後たっぷり子宮に中出しして孕ませたい気分だわ。いいよな？　今日も俺たちの精液でいっぱいにしてやるよ！"
    }
  },

  "hgbc_intro_cafe_0040": {
    "ID": "hgbc_intro_cafe_0040",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0040a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "うわぁ……[=Name,NPC_M,0,CallName]の目の前で堂々と彼の妻にここまで下品に言うなんて……このクラブ、予想以上にハードだな。"
    }
  },

  "hgbc_intro_cafe_0040a": {
    "ID": "hgbc_intro_cafe_0040a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0040b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "でも……なんか興奮する。[=Name,NPC_F,2,CallName]さんがあっさり受け入れてる姿を見てるだけで、俺のチンポも熱くなってきた……"
    }
  },

  "hgbc_intro_cafe_0040b": {
    "ID": "hgbc_intro_cafe_0040b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0041",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "横目で[=Name,Maid,0,CallName]を見ると、顔を赤らめながらも二人の男の露骨な言葉にじっと耳を傾けている……。恥ずかしがってるけど、完全に引いてはいない。むしろ少しずつこの空気に飲まれ始めているみたいだ。"
    }
  },

  "hgbc_intro_cafe_0041": {
    "ID": "hgbc_intro_cafe_0041",
