  "hgbc_intro_cafe_0034": {
    "ID": "hgbc_intro_cafe_0034",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0034a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……マジかよ。本気で全裸が普通なのか……しかも[=Name,NPC_M,0,CallName]本人が笑いながら堂々と言ってる。ここの基準、思ってた以上にぶっ飛んでるな。"
    }
  },

  "hgbc_intro_cafe_0034a": {
    "ID": "hgbc_intro_cafe_0034a",
