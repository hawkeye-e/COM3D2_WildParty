  "hgbc_intro_cafe_0031a": {
    "ID": "hgbc_intro_cafe_0031a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0031b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "ふふっ、[=Name,Maid,0,CallName]のこの嫉妬した顔も可愛いけど……その目には明らかに好奇心が混じってる。"
    }
  },

  "hgbc_intro_cafe_0031b": {
    "ID": "hgbc_intro_cafe_0031b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "hgbc_intro_cafe_0032",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "[=Name,NPC_F,2,CallName]さんが堂々と全裸で歩いているのを見て、彼女の中で何かが少しずつ刺激されてる気がする。まだ恥ずかしがってるけど、完全に拒否してる感じじゃないな……いい兆候だ。"
