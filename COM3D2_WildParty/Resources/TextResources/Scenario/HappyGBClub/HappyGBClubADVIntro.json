    "NextStepID": "hgbc_intro_0032",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "[=Name,NPC_M,0,LastName]さんは[=Name,Maid,0,CallName]としばらく酒を酌み交わした後、機嫌よく帰っていった。"
    },
    "FadeData": {
