  "eee_post_yotogi_wall_0001": {
    "ID": "eee_post_yotogi_wall_0001",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_wall_0002",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "イベントはすでに数時間にわたって続いており、予想を遥かに超える大盛況となっていた。"
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "eee_post_yotogi_wall_0002": {
    "ID": "eee_post_yotogi_wall_0002",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_wall_0003",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "会場は表向きは上品な社交の場のように見えるが、ステージの可動式壁の向こう側では、完全に狂った肉便器使用の狂宴が繰り広げられている。"
    }
  },

  "eee_post_yotogi_wall_0003": {
    "ID": "eee_post_yotogi_wall_0003",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_wall_0003a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "お客様たちは俺の妻たちを本物の壁便器のように扱いながら、腰を振り続け、まるで公衆トイレで立ち話をするかのように気軽に世間話を続けていた。"
    }
  },

  "eee_post_yotogi_wall_0003a": {
    "ID": "eee_post_yotogi_wall_0003a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_wall_0004",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "肉便器としてただ突かれるだけの存在に堕とされているはずなのに、メイドたちは恍惚とした表情で激しく喘ぎ、屈辱的な状況にますます興奮し、愛液を垂れ流している。"
    }
  },


