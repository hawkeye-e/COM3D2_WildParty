    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_common_bedroom_0077",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "なんだ、それだけか。心配ないよ。\n俺はいやらしいメイドが大好きだ。心ゆくまで楽しんでいいんだぞ。"
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "eee_post_yotogi_common_bedroom_0077": {
    "ID": "eee_post_yotogi_common_bedroom_0077",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_common_bedroom_0078_Branch",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "……さて。俺はみんなが楽しんでいる姿を見るだけで、すっかりムラムラしてきた。　今は俺の番だ。肉便器妻たちを、ちゃんと愛してやるよ。今夜は寝かせないからな。"
    }
  },

  "eee_post_yotogi_common_bedroom_0078_Branch": {
    "ID": "eee_post_yotogi_common_bedroom_0078_Branch",
    "Type": "BranchByPersonality",
    "WaitingType": "Branch",
    "CharaData": [
