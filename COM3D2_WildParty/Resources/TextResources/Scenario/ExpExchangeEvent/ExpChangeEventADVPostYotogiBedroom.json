    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "ああ、俺は変態夫だ。変態肉便器妻たちとの、最高の組み合わせだろ。"
    }
  },

  "eee_post_yotogi_common_bedroom_0091a": {
    "ID": "eee_post_yotogi_common_bedroom_0091a",
