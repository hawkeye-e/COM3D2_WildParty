  "eee_post_yotogi_common_bedroom_0081": {
    "ID": "eee_post_yotogi_common_bedroom_0081",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_common_bedroom_0081a",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "もちろん構わない。みんなのままがいいよ。\n俺はみんなを愛してる。何があっても、それは絶対に変わらない。"
    }
  },

  "eee_post_yotogi_common_bedroom_0081a": {
    "ID": "eee_post_yotogi_common_bedroom_0081a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_common_bedroom_0082",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "たとえ他の男の精液でいっぱいになっていても、俺の愛情も欲望も、みんなに向けられている。"
    }
  },

  "eee_post_yotogi_common_bedroom_0082": {
    "ID": "eee_post_yotogi_common_bedroom_0082",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_post_yotogi_common_bedroom_0083_Branch",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "ほら……俺のチンポで、たっぷり掻き出してやるから。\n他の男の精液を全部掻き出して、最後には俺の精液だけで子宮を満たしてやるよ。"
    }
  },

  "eee_post_yotogi_common_bedroom_0083_Branch": {
