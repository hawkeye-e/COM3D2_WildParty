  "eee_intro_wall_0026": {
    "ID": "eee_intro_wall_0026",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_wall_0027",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "メイドたちは少しの躊躇いもなく、指示に従って次々と服を脱ぎ捨て、壁の穴に体を滑り込ませていった。壁の向こう側には、俺の妻たち——全員が他の男のチンポを欲しがる淫乱女たちの美味しそうな尻が、ずらりと並んで晒されている。"
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "eee_intro_wall_0027": {
    "ID": "eee_intro_wall_0027",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_wall_0028",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……くっそ、たまらねえ……。この壁尻の光景が俺の性癖を直撃して、チンポが痛いくらいに勃起しちまう。"
    }
  },

  "eee_intro_wall_0028": {
    "ID": "eee_intro_wall_0028",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_wall_0028a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "いけない、いけない……これはお客様のためのイベントだ。俺がここで楽しんじゃダメだ。今日はあくまで客どもに最高の「ユーザー体験」を提供するためのもの……俺の性欲は抑えろ。"
    }
  },

  "eee_intro_wall_0028a": {
    "ID": "eee_intro_wall_0028a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0001",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "ふふっ……でも最高の眺めだ。誰もが一度は夢見る壁尻に、俺の妻たちのエロい尻が並んでいるなんて……\n……まだ本番は始まったばかりだ。我慢だ、我慢。"
    }
  },


