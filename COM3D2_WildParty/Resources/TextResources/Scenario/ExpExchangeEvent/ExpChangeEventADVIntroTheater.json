  "eee_intro_theater_0101": {
    "ID": "eee_intro_theater_0101",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0102",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "あ！　そうかそうか、それは汗か！　なるほどね〜、誤解してごめんな、[=Name,Maid,4,CallName]ちゃん。"
    }
  },

  "eee_intro_theater_0102": {
    "ID": "eee_intro_theater_0102",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0103",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "まあ、[=Name,Maid,4,CallName]。気に入らないなら今すぐ出て行ってもいいぞ？他に喜んでくれるメイドはたくさんいるからな〜。"
    }
  },

  "eee_intro_theater_0103": {
    "ID": "eee_intro_theater_0103",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0104_Branch",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "[=Name,Maid,4,CallName]は数秒間黙り込んだ。へへっ……どんな可愛い返事をしてくれるかな？"
    }
  },

  "eee_intro_theater_0104_Branch": {
