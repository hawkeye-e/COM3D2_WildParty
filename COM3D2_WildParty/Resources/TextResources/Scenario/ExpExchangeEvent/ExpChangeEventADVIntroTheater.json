    }
  },

  "eee_intro_theater_0150": {
    "ID": "eee_intro_theater_0150",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0151",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "ご覧の通り、メイドたちは拘束され、お客様方に誠心誠意ご奉仕する準備を整えております。"
    }
  },

  "eee_intro_theater_0151": {
    "ID": "eee_intro_theater_0151",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0152",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "会場内では飲食もご用意しておりますので、普通の社交クラブのようにお気軽にお楽しみください。"
    }
  },

  "eee_intro_theater_0152": {
    "ID": "eee_intro_theater_0152",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0153",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "もしお疲れを癒されたい場合は、こちらの５体の性処理専用肉便器をどうぞご自由にお使いください。現在も充分に濡れておりますので、いつでもご利用いただけます。"
    }
  },

  "eee_intro_theater_0153": {
    "ID": "eee_intro_theater_0153",
