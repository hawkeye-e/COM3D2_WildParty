  },

  "eee_intro_theater_0161": {
    "ID": "eee_intro_theater_0161",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0162",
    "TalkData": {
      "SpeakerName": "お客様１",
      "Text": "うおお……これはこれは。なんて美しいピンク色のまんこでしょう。愛液が糸を引いて溢れている……実に美味しそうな牝穴です。"
    }
  },

  "eee_intro_theater_0162": {
    "ID": "eee_intro_theater_0162",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0163",
    "TalkData": {
      "SpeakerName": "お客様４",
      "Text": "おお……この尻の形、完璧ですね。触れたくなるような上品な淫肉……はぁ、素晴らしい。"
    }
  },

  "eee_intro_theater_0163": {
    "ID": "eee_intro_theater_0163",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "eee_intro_theater_0164_Branch",
    "TalkData": {
      "SpeakerName": "お客様１",
      "Text": "実にドスケベなまんこだ……こんなに濡らして、チンポを欲しがっているのが丸わかりですな。"
    }
  },

  "eee_intro_theater_0164_Branch": {
