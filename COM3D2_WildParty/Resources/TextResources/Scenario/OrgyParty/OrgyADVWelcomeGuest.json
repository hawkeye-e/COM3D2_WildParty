    "TalkData": {
      "SpeakerName": "お客様",
      "Text": "え……？　みんなって……本気かよ。\n……つまり、俺がこの子たちを好きにしていいってことか？"
    }
  },

  "orgy_wg_0032a": {
    "ID": "orgy_wg_0032a",
