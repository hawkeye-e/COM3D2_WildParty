  "orgy_wg_0032e": {
    "ID": "orgy_wg_0032e",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0032f",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "彼女たちの子宮を徹底的に犯すような行為も、すべて自由です。\n彼女たちの身体のどこを、どのように使おうと……一切の制限はありません。",
      "TextLocalise": {
        "jp": "彼女たちの子宮を徹底的に犯すような行為も、すべて自由です。\n彼女たちの身体のどこを、どのように使おうと……一切の制限はありません。",
        "cht": "閣下可以徹底侵犯她們子宮。\n無論您想如何使用她們身體的哪一寸部位……也完全歡迎。",
        "chs": "阁下可以彻底侵犯她们子宫。 \n无论您想如何使用她们身体的哪一寸部位……也完全欢迎。"
      }

    }
  },

