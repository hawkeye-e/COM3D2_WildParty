  "orgy_wg_0031a": {
    "ID": "orgy_wg_0031a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0031b",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "本日は常連のお客様方に感謝を込めて、『[=ClubName]大感謝祭』を開催します。",
      "TextLocalise": {
        "jp": "本日は常連のお客様方に感謝を込めて、『[=ClubName]大感謝祭』を開催します。",
        "cht": "本店今日將舉辦「[=ClubName]大感謝祭」，以感謝各位貴客一直以來的支持。",
        "chs": "本店今日将举办「[=ClubName]大感谢祭」，以感谢各位贵客一直以来的支持。"
      }

    }
  },

  "orgy_wg_0031b": {
    "ID": "orgy_wg_0031b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0032",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "会場にいるメイドたちは……\nすべて、お客様方の一時的な愛人となります。\n彼女たちを、どのようにお扱いいただいても結構です。",
      "TextLocalise": {
        "jp": "会場にいるメイドたちは……\nすべて、お客様方の一時的な愛人となります。\n彼女たちを、どのようにお扱いいただいても結構です。",
        "cht": "在會場內的一眾女僕……\n都會成為各位賓客的一時的情人。\n請閣下盡情地跟她們做您想要做的事。",
        "chs": "在会场内的一众女仆……\n都会成为各位宾客的一时的情人。\n请閣下尽情地跟她们做您想要做的事。"
      }
    }
  },

  "orgy_wg_0032": {
    "ID": "orgy_wg_0032",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0032a",
    "TalkData": {
      "SpeakerName": "お客様",
      "Text": "え……？　みんなって……本気かよ。\n……つまり、俺がこの子たちを好きにしていいってことか？",
      "SpeakerNameLocalise": {
        "jp": "お客様",
        "cht": "客人",
        "chs": "客人"
      },
      "TextLocalise": {
        "jp": "え……？　みんなって……本気かよ。\n……つまり、俺がこの子たちを好きにしていいってことか？",
        "cht": "欸……？　一眾女僕……這是說真的嗎？\n……也就是說，我隨心所欲地對這些女孩做任何事也可以嗎？",
        "chs": "欸……？　一众女仆……这是说真的吗？ \n……也就是说，我随心所欲地对这些女孩做任何事也可以吗？"
      }
    }
  },

  "orgy_wg_0032a": {
    "ID": "orgy_wg_0032a",
