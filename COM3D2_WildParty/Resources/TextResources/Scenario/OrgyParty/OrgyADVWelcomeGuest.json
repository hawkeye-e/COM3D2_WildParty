  "orgy_wg_0006a": {
    "ID": "orgy_wg_0006a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0007",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "クラブへ到着した俺は、期待を胸に店の入口を見上げる。",
      "TextLocalise": {
        "jp": "クラブへ到着した俺は、期待を胸に店の入口を見上げる。",
        "cht": "抵達後，我雀躍地抬頭望著向俱樂部的入口。",
        "chs": "抵达后，我雀跃地抬头望着向俱乐部的入口。"
      }
    }
  },

  "orgy_wg_0007": {
    "ID": "orgy_wg_0007",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0008",
    "TalkData": {
      "SpecificSpeaker": "",
      "SpeakerName": "お客様",
      "Text": "ふう……やっと着いたぜ。\nオーナーから特別イベントの話が来たから、わざわざ足を伸ばしたんだがな。",
      "SpeakerNameLocalise": {
        "jp": "お客様",
        "cht": "客人",
        "chs": "客人"
      },
      "TextLocalise": {
        "jp": "ふう……やっと着いたぜ。\nオーナーから特別イベントの話が来たから、わざわざ足を伸ばしたんだがな。",
        "cht": "呼……總算到了啊。\n因為老闆說今天有特別活動，所以特地跑來這裏。",
        "chs": "呼……总算到了啊。\n因为老板说今天有特别活动，所以特地跑来这里。"
      }
    }
  },

  "orgy_wg_0008": {
    "ID": "orgy_wg_0008",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_wg_0009_camerapan",
    "TalkData": {
      "SpecificSpeaker": "",
      "SpeakerName": "お客様",
      "Text": "まあ、いつものように可愛いメイドさんに会えれば満足だけど……\nふふっ、今日は何があるんだろうな。",
      "SpeakerNameLocalise": {
        "jp": "お客様",
        "cht": "客人",
        "chs": "客人"
      },
      "TextLocalise": {
        "jp": "まあ、いつものように可愛いメイドさんに会えれば満足だけど……\nふふっ、今日は何があるんだろうな。",
        "cht": "雖說能見到可愛的女僕，我就相當滿足了……\n嘿嘿，今天會有甚麼有趣的玩意呢。",
        "chs": "虽说能见到可爱的女仆，我就相当满足了……\n嘿嘿，今天会有什么有趣的玩意呢。"
      }
    }
  },

