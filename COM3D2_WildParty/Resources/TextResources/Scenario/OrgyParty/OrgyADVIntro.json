    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "[=ClubName]は順調に回っている。\n俺には、数人の可愛い恋人がいる。"
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "orgy_intro_0005": {
    "ID": "orgy_intro_0005",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……今が、人生で一番幸せな瞬間なんだろう。\n少なくとも、表面的には。"
    }
  },

  "orgy_intro_0005a": {
    "ID": "orgy_intro_0005a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "今の生活に不満なんてない。\nむしろ、恵まれすぎているはずだ。"
    }
  },

  "orgy_intro_0005b": {
    "ID": "orgy_intro_0005b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "それなのに——"
    }
  },

  "orgy_intro_0005c": {
    "ID": "orgy_intro_0005c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005d",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "心のどこかに、ぽっかりと空いた穴が疼いている。"
    }
  },

  "orgy_intro_0005d": {
    "ID": "orgy_intro_0005d",
    "Type": "Camera",
    "WaitingType": "Auto",
