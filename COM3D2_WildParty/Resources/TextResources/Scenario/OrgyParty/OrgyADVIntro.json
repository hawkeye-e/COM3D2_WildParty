  "orgy_intro_0009b": {
    "ID": "orgy_intro_0009b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0009c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "愛する彼女たちが、他人に犯されて、\n本気で喘いで、\n獣のように乱れる姿を。",
      "TextLocalise": {
        "jp": "愛する彼女たちが、他人に犯されて、\n本気で喘いで、\n獣のように乱れる姿を。",
        "cht": "想要心愛的戀人被其他男人侵犯，\n想聽她們那充滿情慾地呻吟，\n想看她們像野獸般放縱交配的模樣。",
        "chs": "想要心爱的恋人被其他男人侵犯，\n想听她们那充满情欲地呻吟，\n想看她们像野兽般放纵交配的模样。"
      }
    }
  },

  "orgy_intro_0009c": {
    "ID": "orgy_intro_0009c",
    "Type": "Camera",
    "WaitingType": "Auto",
    "NextStepID": "orgy_intro_0009d",
    "CameraData": {
      "FixedPointData": {
        "PosString": "-1.22, 2.38, -1.14",
        "TargetPosString": "-0.83, 1.97, -1.84",
        "AroundAngleString": "-209.24, 27.35",
        "Distance": 0.3
      }
    }
  },

  "orgy_intro_0009d": {
    "ID": "orgy_intro_0009d",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0009e",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "どれほど淫乱で、\nどれほど欲深い本性を持っているのか、\nそのすべてを、この目で確かめたい。",
      "TextLocalise": {
        "jp": "どれほど淫乱で、\nどれほど欲深い本性を持っているのか、\nそのすべてを、この目で確かめたい。",
        "cht": "無論她們有多麼淫蕩、\n對男人有多麼飢渴，\n我都希望用這雙眼徹底確認。",
        "chs": "无论她们有多么淫荡、\n对男人有多么饥渴，\n我都希望用这双眼彻底确认。"
      }
    }
  },

