  "orgy_intro_0039": {
    "ID": "orgy_intro_0039",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0039a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "そして俺は、数人の常連客へ連絡を入れ、パーティーへ招待した。",
      "TextLocalise": {
        "jp": "そして俺は、数人の常連客へ連絡を入れ、パーティーへ招待した。",
        "cht": "接著，我聯絡了幾位常客並邀請他們參加這個派對。",
        "chs": "接着，我联络了几位常客并邀请他们参加这个派对。"
      }
    }
  },

  "orgy_intro_0039a": {
    "ID": "orgy_intro_0039a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0039b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……本当に、やってしまうのか。\n愛する彼女たちを、他の男のものにするなんて。",
      "TextLocalise": {
        "jp": "……本当に、やってしまうのか。\n愛する彼女たちを、他の男のものにするなんて。",
        "cht": "……真的要這麼做了嗎？\n竟要把自己深愛的女僕，拱手讓給其他男人上。",
        "chs": "……真的要这么做了吗？\n竟要把自己深爱的女仆，拱手让给其他男人上。"
      }
    }
  },

  "orgy_intro_0039b": {
    "ID": "orgy_intro_0039b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0040",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "頭では馬鹿げていると叫んでいるのに、\nこの身体と心は、期待で震えている。",
      "TextLocalise": {
        "jp": "頭では馬鹿げていると叫んでいるのに、\nこの身体と心は、期待で震えている。",
        "cht": "雖然理智上知道這太荒謬了，\n但這副身體與心靈，卻因期待而輕輕顫抖著。",
        "chs": "虽然理智上知道这太荒谬了，\n但这副身体与心灵，却因期待而轻轻颤抖着。"
      }
    }
  },

  "orgy_intro_0040": {
    "ID": "orgy_intro_0040",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0041",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "ああ……彼女たちの「本当の姿」を、見たい。\nどうしようもなく、見たくて仕方ない。",
      "TextLocalise": {
        "jp": "ああ……彼女たちの「本当の姿」を、見たい。\nどうしようもなく、見たくて仕方ない。",
        "cht": "啊……很快就可以好好觀賞她們的「真實的樣子」了。\n實在是無可救藥地想要看啊……",
        "chs": "啊……很快就可以好好观赏她们的「真实的样子」了。 \n实在是无可救药地想要看啊……"
      }
    }
  },

