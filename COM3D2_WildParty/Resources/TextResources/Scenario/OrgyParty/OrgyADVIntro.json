  "orgy_intro_0004": {
    "ID": "orgy_intro_0004",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "[=ClubName]は順調に回っている。\n俺には、数人の可愛い恋人がいる。",
      "TextLocalise": {
        "jp": "[=ClubName]は順調に回っている。\n俺には、数人の可愛い恋人がいる。",
        "cht": "[=ClubName]的經營發展順利。\n而我也在這裏交了好幾個可愛的戀人。",
        "chs": "[=ClubName]的经营发展顺利。\n而我也在这里交了好几个可爱的恋人。"
      }
    },
    "FadeData": {
      "IsFadeIn": true,
      "IsFadeOut": false
    }
  },

  "orgy_intro_0005": {
    "ID": "orgy_intro_0005",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……今が、人生で一番幸せな瞬間なんだろう。\n少なくとも、表面的には。",
      "TextLocalise": {
        "jp": "……今が、人生で一番幸せな瞬間なんだろう。\n少なくとも、表面的には。",
        "cht": "……現在大概就是我人生中最幸福的時間吧。\n至少表面看起上來是這樣。",
        "chs": "……现在大概就是我人生中最幸福的时间吧。\n至少表面看起上来是这样。"
      }
    }
  },

  "orgy_intro_0005a": {
    "ID": "orgy_intro_0005a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "今の生活に不満なんてない。\nむしろ、恵まれすぎているはずだ。",
      "TextLocalise": {
        "jp": "今の生活に不満なんてない。\nむしろ、恵まれすぎているはずだ。",
        "cht": "我對現狀沒有絲毫一點的不滿。\n倒不如說，我實在是過得太幸福了。",
        "chs": "我对现状没有丝毫一点的不满。\n倒不如说，我实在是过得太幸福了。"
      }
    }
  },

  "orgy_intro_0005b": {
    "ID": "orgy_intro_0005b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "それなのに——",
      "TextLocalise": {
        "jp": "それなのに——",
        "cht": "可是——",
        "chs": "可是——"
      }
    }
  },

  "orgy_intro_0005c": {
    "ID": "orgy_intro_0005c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0005d",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "心のどこかに、ぽっかりと空いた穴が疼いている。",
      "TextLocalise": {
        "jp": "心のどこかに、ぽっかりと空いた穴が疼いている。",
        "cht": "心底裏的某處，像是有個空洞般的隱隱作痛。",
        "chs": "心底里的某处，像是有个空洞般的隐隐作痛。"
      }
    }
  },

