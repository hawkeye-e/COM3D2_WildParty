    "NextStepID": "orgy_intro_0009a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……もっと、見たい。",
      "TextLocalise": {
        "jp": "……もっと、見たい。",
        "cht": "……可是，我還是想要看。",
        "chs": "……可是，我还是想要看。"
      }
    }
  },

  "orgy_intro_0009a": {
    "ID": "orgy_intro_0009a",
    "Type": "Camera",
    "WaitingType": "Auto",
    "NextStepID": "orgy_intro_0009b",
    "CameraData": {
      "FixedPointData": {
        "PosString": "-1.22, 2.38, -1.14",
        "TargetPosString": "-0.83, 1.97, -1.84",
