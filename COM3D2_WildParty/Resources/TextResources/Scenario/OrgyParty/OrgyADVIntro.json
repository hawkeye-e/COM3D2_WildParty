  "orgy_intro_0006": {
    "ID": "orgy_intro_0006",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……ああ。\n俺はもう、その「足りないもの」に気づいている。",
      "TextLocalise": {
        "jp": "……ああ。\n俺はもう、その「足りないもの」に気づいている。",
        "cht": "……嗯。\n其實我心裏很明白，我內心那缺少的是甚麼樣的東西。",
        "chs": "……嗯。\n其实我心里很明白，我内心那缺少的是什么样的东西。"
      }
    }
  },

  "orgy_intro_0006a": {
    "ID": "orgy_intro_0006a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "スワッピング夜伽の後、彼女たちが見せた顔。",
      "TextLocalise": {
        "jp": "スワッピング夜伽の後、彼女たちが見せた顔。",
        "cht": "在交換夜伽之後，她們流露的神情。",
        "chs": "在交换夜伽之后，她们流露的神情。"
      }
    }
  },

  "orgy_intro_0006b": {
    "ID": "orgy_intro_0006b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの蕩けた表情。\nあの潤んだ瞳。\nあの紅潮した頰。",
      "TextLocalise": {
        "jp": "あの蕩けた表情。\nあの潤んだ瞳。\nあの紅潮した頰。",
        "cht": "那如癡如醉的神情。\n那春心蕩漾的雙眸。\n那白裏透紅的雙頰。",
        "chs": "那如痴如醉的神情。\n那春心荡漾的双眸。\n那白里透红的双颊。"
      }
    }
  },

  "orgy_intro_0006c": {
    "ID": "orgy_intro_0006c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006d",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの激しく乱れた髪。\nあの淫らに濡れた唇。\nあの熱い吐息。",
      "TextLocalise": {
        "jp": "あの激しく乱れた髪。\nあの淫らに濡れた唇。\nあの熱い吐息。",
        "cht": "那凌亂不堪的秀髮。\n那柔軟濕潤的雙唇。\n那灼熱如火的喘息。",
        "chs": "那凌乱不堪的秀发。\n那柔软湿润的双唇。\n那灼热如火的喘息。"
      }
    }
  },

  "orgy_intro_0006d": {
    "ID": "orgy_intro_0006d",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006e",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの甘く掠れた声。\nあの卑猥な仕草。\nあの女らしい腰のくねらせ方。",
      "TextLocalise": {
        "jp": "あの甘く掠れた声。\nあの卑猥な仕草。\nあの女らしい腰のくねらせ方。",
        "cht": "那甜美沙啞的聲線。\n那淫猥放蕩的舉止。\n那搔首弄姿的模樣。",
        "chs": "那甜美沙哑的声线。\n那淫猥放荡的举止。\n那搔首弄姿的模样。"
      }
    }
  },

  "orgy_intro_0006e": {
    "ID": "orgy_intro_0006e",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006f",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……",
      "TextLocalise": {
        "jp": "……",
        "cht": "……",
        "chs": "……"
      }
    }
  },

  "orgy_intro_0006f": {
    "ID": "orgy_intro_0006f",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006g",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "普段、俺を抱く時よりも、ずっと妖しくて、美しかった。",
      "TextLocalise": {
        "jp": "普段、俺を抱く時よりも、ずっと妖しくて、美しかった。",
        "cht": "比起平時跟我造的時候，顯得格外的妖豔迷人。",
        "chs": "比起平时跟我造的时候，显得格外的妖艳迷人。"
      }
    }
  },

  "orgy_intro_0006g": {
    "ID": "orgy_intro_0006g",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006h",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あんな顔を、俺はまだ一度も見せてもらったことがない。",
      "TextLocalise": {
        "jp": "あんな顔を、俺はまだ一度も見せてもらったことがない。",
        "cht": "那副模樣，至今在跟我一起時我連一次都沒見過。",
        "chs": "那副模樣，至今在跟我一起时我连一次都没见过。"
      }
    }
  },

  "orgy_intro_0006h": {
    "ID": "orgy_intro_0006h",
