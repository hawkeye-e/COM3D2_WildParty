    "NextStepID": "orgy_intro_0035a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……いや。\n本当は、引き返したくない。",
      "TextLocalise": {
        "jp": "……いや。\n本当は、引き返したくない。",
        "cht": "……不。\n說真心話，我根本沒想過回頭。",
        "chs": "……不。\n说真心话，我根本没想过回头。"
      }
    }
