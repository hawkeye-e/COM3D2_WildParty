  "orgy_intro_0007": {
    "ID": "orgy_intro_0007",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0008",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "分かっている。\n彼女たちは俺の大切な恋人だ。",
      "TextLocalise": {
        "jp": "分かっている。\n彼女たちは俺の大切な恋人だ。",
        "cht": "我明白的。\n我完全明白，她們是我重要的戀人。",
        "chs": "我明白的。 \n我完全明白，她们是我重要的恋人。"
      }
    }
  },

  "orgy_intro_0007a": {
    "ID": "orgy_intro_0007a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0007b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "誰にも渡してはいけない。\n触れさせてはいけない存在だ。",
      "TextLocalise": {
        "jp": "誰にも渡してはいけない。\n触れさせてはいけない存在だ。",
        "cht": "我絕不應該將她們交給任何人。\n絕不能隨便讓其他男人觸碰她們。",
        "chs": "我绝不应该将她们交给任何人。 \n绝不能随便让其他男人触碰她们。"
      }
    }
  },

  "orgy_intro_0007b": {
    "ID": "orgy_intro_0007b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0008",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "それなのに——",
      "TextLocalise": {
        "jp": "それなのに——",
        "cht": "儘管如此——",
        "chs": "尽管如此——"
      }
    }
  },

  "orgy_intro_0008": {
    "ID": "orgy_intro_0008",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0008a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "どうしても、この妄想が頭から離れない。\nやってはいけないことだと、頭では分かっているのに。\n見ちゃいけないものだと、理解しているのに。",
      "TextLocalise": {
        "jp": "どうしても、この妄想が頭から離れない。\nやってはいけないことだと、頭では分かっているのに。\n見ちゃいけないものだと、理解しているのに。",
        "cht": "可是我還是沒有辦法抹走這個謊謬的想法。\n我很清楚這並非可試探的行為。\n也很清楚這並非可窺視的東西。",
        "chs": "可是我还是没有办法抹走这个谎谬的想法。\n我很清楚这并非可试探的行为。\n也很清楚这并非可窥视的东西。"
      }
    }
  },

  "orgy_intro_0008a": {
    "ID": "orgy_intro_0008a",
