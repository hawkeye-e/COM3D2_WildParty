    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……ああ。\n俺はもう、その「足りないもの」に気づいている。"
    }
  },

  "orgy_intro_0006a": {
    "ID": "orgy_intro_0006a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "スワッピング夜伽の後、彼女たちが見せた顔。"
    }
  },

  "orgy_intro_0006b": {
    "ID": "orgy_intro_0006b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの蕩けた表情。\nあの潤んだ瞳。\nあの紅潮した頰。"
    }
  },

  "orgy_intro_0006c": {
    "ID": "orgy_intro_0006c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006d",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの激しく乱れた髪。\nあの淫らに濡れた唇。\nあの熱い吐息。"
    }
  },

  "orgy_intro_0006d": {
    "ID": "orgy_intro_0006d",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006e",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あの甘く掠れた声。\nあの卑猥な仕草。\nあの女らしい腰のくねらせ方。"
    }
  },

  "orgy_intro_0006e": {
    "ID": "orgy_intro_0006e",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006f",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……"
    }
  },

  "orgy_intro_0006f": {
    "ID": "orgy_intro_0006f",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006g",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "普段、俺を抱く時よりも、ずっと妖しくて、美しかった。"
    }
  },

  "orgy_intro_0006g": {
    "ID": "orgy_intro_0006g",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0006h",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "あんな顔を、俺はまだ一度も見せてもらったことがない。"
    }
  },

