  "orgy_intro_0027": {
    "ID": "orgy_intro_0027",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0029",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "だが、予想に反して彼女たちはそれほど嫌がっていなかった。\nむしろ……どこか興味深げで、期待すら感じさせる目をしている。"
    }
  },


  "orgy_intro_0029": {
    "ID": "orgy_intro_0029",
    "Type": "Chara",
    "WaitingType": "Auto",
    "NextStepID": "orgy_intro_0030",
    "CharaData": [
      {
        "Type": "F",
        "ArrayPosition": 0,
        "Visible": true,
        "WaitLoad": true,
        "FaceAnime": "RandomHorny",
        "FaceBlend": "頬２涙０"
      },
      {
        "Type": "F",
        "ArrayPosition": 1,
        "Visible": true,
        "WaitLoad": true,
        "FaceAnime": "RandomHorny",
        "FaceBlend": "頬２涙０"
      },
      {
        "Type": "F",
        "ArrayPosition": 2,
        "Visible": true,
        "WaitLoad": true,
        "FaceAnime": "RandomHorny",
        "FaceBlend": "頬２涙０"
      }
    ]
  },

  "orgy_intro_0030": {
    "ID": "orgy_intro_0030",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0031",
    "TalkData": {
      "SpecificSpeaker": "Owner",
      "Text": "……以上だ。\n無茶な話だって、自分でも分かってる。これはただの提案だ。嫌ならはっきり断ってくれ。俺は無理強いするつもりはない。"
    }
  },

  "orgy_intro_0031": {
    "ID": "orgy_intro_0031",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0031a",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "……くそっ。\nなんでこんなに興奮しているんだ。"
    }
  },

  "orgy_intro_0031a": {
    "ID": "orgy_intro_0031a",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0031b",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "彼女が他の男に抱かれる姿を想像しただけで、\n胸が締め付けられるような感覚がする。"
    }
  },

  "orgy_intro_0031b": {
    "ID": "orgy_intro_0031b",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0031c",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "これは間違っている。\n愛しているはずの彼女を、他の男に渡そうとしている。"
    }
  },

  "orgy_intro_0031c": {
    "ID": "orgy_intro_0031c",
    "Type": "Talk",
    "WaitingType": "Click",
    "NextStepID": "orgy_intro_0032_Branch",
    "TalkData": {
      "SpecificSpeaker": "Narrative",
      "Text": "それなのに——\nこの疼きが、止まらない。"
    }
  },


  "orgy_intro_0032_Branch": {
    "ID": "orgy_intro_0032_Branch",
    "Type": "BranchByPersonality",
    "WaitingType": "Branch",
    "CharaData": [
