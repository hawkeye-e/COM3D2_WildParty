    "WaitingType": "Click",
    "NextStepID": "pam_post_yotogi_0011",
    "TalkData": {
      "SpecificSpeaker": "Maid",
      "UseBranchIndex": true,
      "Text": "おぅぅう……！　こんなぶっといチンポ突っ込んでくださって、ありがとうございます……！　わたしのチンコキ穴で、たくさん気持ちよくなってください……！",
      "VoiceData": {
        "Childhood": {
          "VoiceFile": "H10_BL_57021.ogg",
          "IsChoppingAudio": false
        }
      }
    }
  },

  "pam_post_yotogi_0020_T_Childhood": {
    "ID": "pam_post_yotogi_0020_T_Childhood",
