    "WaitingType": "Click",
    "NextStepID": "pam_post_yotogi_0021",
    "TalkData": {
      "SpecificSpeaker": "Maid",
      "UseBranchIndex": true,
      "Text": "はぁっ、はひぃい！　腰を振るたびに、頭が痺れるくらい、気持ちよくてっ、はひゅぅう！　チンポのことしか、考えられなくなってきます……！",
      "VoiceData": {
        "Childhood": {
          "VoiceFile": "H10_BL_56984.ogg",
          "IsChoppingAudio": false
        }
      }
    }
  },

  "pam_post_yotogi_0030_T_Childhood": {
    "ID": "pam_post_yotogi_0030_T_Childhood",
