    "WaitingType": "Click",
    "NextStepID": "pam_post_yotogi_0031",
    "TalkData": {
      "SpecificSpeaker": "Maid",
      "UseBranchIndex": true,
      "Text": "んおっ、ぉひぅう！　チンポ、わたしの中でびくびくしてりゅっ、おっぉお！　嬉しいっ、幸せぇ！　もっとびくびくしてっ、わたしの穴で感じてくだひゃいぃ！",
      "VoiceData": {
        "Childhood": {
          "VoiceFile": "H10_BL_57039.ogg",
          "IsChoppingAudio": false
        }
      }
    }
  },

  "pam_post_yotogi_0040_T_Childhood": {
